<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.moviemanagerexam.ticketgui.MainController"
            prefHeight="720.0" prefWidth="1280.0" stylesheets="@style.css">
    <left>
        <VBox prefWidth="240.0" styleClass="sidebar">
            <children>
                <VBox spacing="5">
                    <Text text="Ticket System" styleClass="header-text" />
                    <Text text="Management Console" styleClass="sub-header-text" />
                </VBox>
                
                <Region VBox.vgrow="ALWAYS" prefHeight="40" />
                
                <VBox spacing="10">
                    <Button fx:id="btnDashboard" text="Dashboard" styleClass="sidebar-button" maxWidth="Infinity" onAction="#handleDashboard" />
                    <Button fx:id="btnEvents" text="Events" styleClass="sidebar-button" maxWidth="Infinity" onAction="#handleEvents" />
                    <Button fx:id="btnUsers" text="User Management" styleClass="sidebar-button" maxWidth="Infinity" onAction="#handleUsers" />
                    <Button fx:id="btnSpecialTickets" text="Special Tickets" styleClass="sidebar-button" maxWidth="Infinity" onAction="#handleSpecialTickets" />
                </VBox>
                
                <Region VBox.vgrow="ALWAYS" />
                
                <VBox spacing="10">
                    <Separator />
                    <Button text="Settings" styleClass="sidebar-button" maxWidth="Infinity" />
                    <Button text="Logout" styleClass="sidebar-button" maxWidth="Infinity" />
                </VBox>
            </children>
        </VBox>
    </left>
    
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area">
            <!-- Dynamic content will be loaded here -->
            <VBox spacing="20">
                <Text text="Welcome back, Administrator" styleClass="header-text" />
                <FlowPane hgap="20" vgap="20">
                    <VBox styleClass="card" prefWidth="250" prefHeight="150">
                        <Text text="Total Events" fill="#a6adc8" />
                        <Label text="24" style="-fx-font-size: 36px; -fx-text-fill: white;" />
                    </VBox>
                    <VBox styleClass="card" prefWidth="250" prefHeight="150">
                        <Text text="Tickets Sold" fill="#a6adc8" />
                        <Label text="1,248" style="-fx-font-size: 36px; -fx-text-fill: white;" />
                    </VBox>
                    <VBox styleClass="card" prefWidth="250" prefHeight="150">
                        <Text text="Active Coordinators" fill="#a6adc8" />
                        <Label text="8" style="-fx-font-size: 36px; -fx-text-fill: white;" />
                    </VBox>
                </FlowPane>
                
                <Text text="Recent Activity" styleClass="header-text" />
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <VBox fx:id="activityList" spacing="10">
                        <!-- Activity items will be added here -->
                    </VBox>
                </ScrollPane>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
